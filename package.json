{
  "name": "inventory-track-api",
  "version": "1.0.0",
  "private": true,
  "main": "src/server.js",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev:backend": "nodemon src/server.js",
    "dev:frontend": "npm --prefix ../../frontend run dev",
    "dev:all": "concurrently -n backend,frontend -c cyan,magenta \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev": "npm run dev:backend",
    "build:frontend": "npm --prefix ../../frontend install && npm --prefix ../../frontend run build",
    "build": "npm run build:frontend",
    "start": "node src/server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.11"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "mysql2": "^3.18.2"
  }
}
